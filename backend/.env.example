PORT=3001
CORS_ORIGIN=http://127.0.0.1:5500
HARDHAT_RPC_URL=http://127.0.0.1:8545

# Hardhat account #0 private key — local dev only, NOT a real wallet
BACKEND_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

MISTRAL_API_KEY=your_mistral_api_key_here

# ── Optional: Voice Message Support (Whisper transcription) ───────────────────
# Leave blank to disable voice transcription. Get a key at https://platform.openai.com
OPENAI_API_KEY=
WHISPER_MODEL=whisper-1

# ── Optional: Telegram Bot Interface ──────────────────────────────────────────
# Leave blank to disable the bot. Create one with @BotFather on Telegram.
TELEGRAM_BOT_TOKEN=

# Fill these after running: npm run deploy (from root)
ROLE_MANAGER_ADDRESS=0x
ANNOUNCEMENT_LOG_ADDRESS=0x
DOCUMENT_REGISTRY_ADDRESS=0x
ACKNOWLEDGMENT_LOG_ADDRESS=0x
